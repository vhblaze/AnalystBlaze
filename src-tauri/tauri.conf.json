{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AnalystBlaze",
  "version": "0.1.4",
  "identifier": "com.analystblaze.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AnalystBlaze",
        "width": 1180,
        "height": 760,
        "minWidth": 1040,
        "minHeight": 680,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data:; font-src 'self' data:; connect-src 'self' http://localhost:* https://api.analystblaze.com https://analystblaze-server-production.up.railway.app; frame-src 'none'; object-src 'none'; base-uri 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "installer/helper-service.ps1": "helper-service.ps1"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "installer/hooks.nsh"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["analystblaze"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDREM0Q3OTIwNzczNjNFMTgKUldRWVBqWjNJSGs5VFc0UEVicC81cXpxUzF5MFNTQ01EMHM5QW5wUlg2Rmk0cGluREdXajJwQ0sK",
      "endpoints": [
        "https://analystblaze-server-production.up.railway.app/api/v1/updates/manifest?target={{target}}&arch={{arch}}&current_version={{current_version}}"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
