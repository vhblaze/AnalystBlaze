# Open-core safety: every VITE_* value is bundled into the public desktop UI.
# Keep secrets, service-role keys, payment logic, and user management on the web/API side.

# Front-end UI telemetry. Leave empty to keep events buffered locally without sending.
VITE_ANALYSTBLAZE_TELEMETRY_URL=
VITE_ANALYSTBLAZE_TELEMETRY_FLUSH_INTERVAL_MS=3600000
VITE_ANALYSTBLAZE_TELEMETRY_MAX_EVENTS=500

# Optional public web links. They are navigation targets only; backend remains the source of truth.
VITE_ANALYSTBLAZE_ACCOUNT_URL=https://app.example.com/configuration
VITE_ANALYSTBLAZE_BILLING_URL=https://app.example.com/billing
VITE_ANALYSTBLAZE_INSIGHTS_URL=https://app.example.com/insights

# Backend/API authority. User, plan, commands, telemetry, and insights are decided here.
# Optional browser-dev fallbacks. HTTP is accepted only in dev for localhost/127.0.0.1.
# In production, ANALYSTBLAZE_API_URL and ANALYSTBLAZE_WEB_URL must use https://.
VITE_ANALYSTBLAZE_API_URL=http://localhost:8000
VITE_ANALYSTBLAZE_WEB_LOGIN_URL=http://localhost:3000/login?desktop=1&redirect_uri=analystblaze%3A%2F%2Fauth
ANALYSTBLAZE_ENV=development
ANALYSTBLAZE_API_URL=http://localhost:8000
ANALYSTBLAZE_WEB_URL=http://localhost:3000

# Backend telemetry privacy. Defaults are minimized: no raw active-window names,
# no raw process list, no SSID, no hostname, and DNS/gateway are summarized.
ANALYSTBLAZE_DIAGNOSTIC_TELEMETRY=0
ANALYSTBLAZE_TELEMETRY_INCLUDE_SSID=0
ANALYSTBLAZE_TELEMETRY_INCLUDE_HOSTNAME=0
ANALYSTBLAZE_FAMILY_DETAIL_CONSENT=0
