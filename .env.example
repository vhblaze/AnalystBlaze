# Open-core safety: every VITE_* value is bundled into the public desktop UI.
# Keep secrets, service-role keys, payment logic, and user management on the web/API side.

# Front-end UI telemetry. Leave empty to keep events buffered locally without sending.
VITE_ANALYSTBLAZE_TELEMETRY_URL=
VITE_ANALYSTBLAZE_TELEMETRY_FLUSH_INTERVAL_MS=3600000
VITE_ANALYSTBLAZE_TELEMETRY_MAX_EVENTS=500

# Optional AI insights endpoint used by the desktop UI.
VITE_ANALYSTBLAZE_INSIGHTS_URL=

# Optional public web links. Payment and user management live outside the desktop app.
VITE_ANALYSTBLAZE_ACCOUNT_URL=https://app.example.com/account
VITE_ANALYSTBLAZE_BILLING_URL=https://app.example.com/billing

# Optional browser-dev fallbacks. The Rust agent reads ANALYSTBLAZE_API_URL
# and ANALYSTBLAZE_WEB_URL from the process environment when running Tauri.
VITE_ANALYSTBLAZE_API_URL=http://localhost:8000
VITE_ANALYSTBLAZE_WEB_LOGIN_URL=http://localhost:3000/login?desktop=1&redirect_uri=analystblaze%3A%2F%2Fauth
ANALYSTBLAZE_API_URL=http://localhost:8000
ANALYSTBLAZE_WEB_URL=http://localhost:3000
